{
  "name": "board-game-container",
  "version": "0.1.0",
  "private": true,
  "description": "A server-authoritative online board-game platform, launching as a WeChat Mini Game.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/bootstrap.ps1",
    "env:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/check-env.ps1",
    "cocos:open": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/open-cocos.ps1",
    "cocos:build:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/build-cocos-web.ps1",
    "cocos:build:wechat": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/build-cocos-wechat.ps1",
    "cocos:preview": "node tools/serve-static.mjs apps/game-client/build/web-desktop 4173",
    "wechat:open": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/open-wechat-devtools.ps1",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/start-dev.ps1",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck && pnpm typecheck:tools",
    "typecheck:tools": "tsc --noEmit -p tools/tsconfig.json",
    "test": "pnpm -r --if-present test",
    "format": "prettier --write \"apps/*/**/*.{ts,json}\" \"packages/**/*.{ts,json}\" \"games/**/*.{ts,json}\" \"tools/**/*.{ts,mjs}\" \"*.json\"",
    "format:check": "prettier --check \"apps/*/**/*.{ts,json}\" \"packages/**/*.{ts,json}\" \"games/**/*.{ts,json}\" \"tools/**/*.{ts,mjs}\" \"*.json\"",
    "cocos:syntax": "node tools/check-cocos-syntax.mjs",
    "cocos:typecheck": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/check-cocos-types.ps1",
    "check": "pnpm typecheck && pnpm cocos:syntax && pnpm cocos:typecheck && pnpm test && pnpm build",
    "smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/smoke-test.ps1",
    "cloudbase:login": "tcb login",
    "cloudbase:envs": "tcb env list",
    "cloudbase:deploy:dry": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/deploy-cloudbase.ps1 -ValidateOnly",
    "cloudbase:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tools/deploy-cloudbase.ps1"
  },
  "devDependencies": {
    "@cloudbase/cli": "3.6.2",
    "@types/node": "24.13.3",
    "@types/ws": "8.18.1",
    "prettier": "3.9.5",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "creator": {
    "version": "3.8.8"
  },
  "uuid": "4d0c87b8-2e21-44e2-b1d8-63885e3ab9e7"
}
